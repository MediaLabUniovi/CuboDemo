# Copia este fichero a .env.local para desarrollo local con Upstash Redis
# Obtén estos valores desde: Vercel Dashboard → Integrations → Upstash Redis → tu base de datos

UPSTASH_REDIS_REST_URL="https://xxxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="xxxxx"

# Autenticación
AUTH_PASSWORD="la-contraseña-que-elijas"
AUTH_SECRET="un-string-aleatorio-largo-para-la-cookie"
